model User {
    id           String       @id @default(uuid())
    name         String       @db.VarChar(255)
    email        String       @unique
    password     String
    activeStatus activeStatus @default(Active)
    role         Role         @default(user)
    createAt     DateTime     @default(now())
    updateAt     DateTime     @default(now())
    profile      Profie?

    posts Post[]

    comments Comment[]

    @@map("users")
}
